{
  "manifest_version": 3,
  "name": "Giffeur",
  "version": "1.1.0",
  "description": "Capture any screen area as an animated GIF with a modern, intuitive interface",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabCapture",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Démarrer/Arrêter l'enregistrement"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "lib/*.js",
        "gallery.html",
        "gallery.css",
        "gallery.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}